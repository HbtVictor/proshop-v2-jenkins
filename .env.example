# Copier ce fichier en `.env` à la racine et remplir les vraies valeurs.
# Le `.env` réel est listé dans `.gitignore` et NE doit PAS être commité.

# --- Backend Node/Express ---
NODE_ENV=production
PORT=5000

# --- MongoDB (URI utilisée par le backend pour se connecter au conteneur DB) ---
# Le hostname `mongo` est le nom du service dans docker-compose.yml
MONGO_URI=mongodb://mongo:27017/proshop

# --- Identifiants MongoDB (utilisés par le conteneur mongo lui-même) ---
MONGO_INITDB_ROOT_USERNAME=proshop
MONGO_INITDB_ROOT_PASSWORD=changeme-in-real-env

# --- Auth ---
JWT_SECRET=changeme-generate-a-long-random-string

# --- PayPal sandbox ---
PAYPAL_CLIENT_ID=
PAYPAL_APP_SECRET=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
